{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "typescript": {
      "command": ["npx", "-y", "typescript-language-server", "--stdio"],
      "initialization": {
        "tsserver": {
          "path": "../node_modules/typescript/lib/tsserver.js"
        }
      }
    },
    "html": {
      "command": ["npx", "--package=vscode-langservers-extracted", "vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css": {
      "command": ["npx", "--package=vscode-langservers-extracted", "vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    }
  }
}
